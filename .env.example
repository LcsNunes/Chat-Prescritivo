OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen3:8b
EMBEDDING_MODEL=qwen3-embedding:4b
FALLBACK_LLM_MODEL=qwen3:4b

DATA_PATH=data/banner.csv
DOCS_PATH=data/docs
CACHE_PATH=cache

# Optional PostgreSQL event store. When DATABASE_URL is empty, events use DATA_PATH.
# DATABASE_URL=postgresql://chat_prescritivo:chat_prescritivo@localhost:5432/chat_prescritivo
EVENTS_TABLE=maintenance_events
POSTGRES_SEED_FROM_CSV=true

MIN_FAULT_SIMILARITY=0.55
MIN_CHUNK_SIMILARITY=0.50
TOP_K_CHUNKS=5
SIMILAR_EVENTS_LIMIT=5

ENABLE_OCR=true
OCR_STRATEGY=auto
OCR_LANG=por+eng
# Windows example:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
